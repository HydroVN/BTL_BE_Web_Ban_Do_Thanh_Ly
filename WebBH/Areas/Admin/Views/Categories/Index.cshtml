@model IEnumerable<WebBH.Models.Category>
@{
    ViewData["Title"] = "Quản lý Danh mục";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<link rel="stylesheet" href="~/css/admin-category.css" />

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold m-0 text-white">Quản lý Danh mục</h2>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-success" onclick="openCategoryModal(0)">
            <i class="bi bi-folder-plus me-2"></i>Thêm danh mục
        </button>
    </div>
</div>

<div class="card shadow-sm border-0 bg-dark text-white">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-dark mb-0 align-middle category-table">
                <thead class="bg-secondary bg-opacity-25">
                    <tr>
                        <th class="ps-4" style="width: 5%">ID</th>
                        <th style="width: 30%">Tên danh mục</th>
                        <th style="width: 40%">Mô tả</th>
                        <th class="text-center" style="width: 15%">Số sản phẩm</th>
                        <th class="text-end pe-4" style="width: 10%">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">Chưa có danh mục nào.</td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        <tr class="category-row">
                            <td class="ps-4 text-muted">#@item.CategoryId</td>
                            <td class="fw-bold text-info">@item.Name</td>
                            <td><small class="text-muted">@(string.IsNullOrEmpty(item.Description) ? "--" : item.Description)</small></td>
                            <td class="text-center">
                                <span class="badge bg-primary rounded-pill">@item.Products.Count()</span>
                            </td>
                            <td class="text-end pe-4">
                                <button class="btn btn-sm btn-outline-warning me-2" onclick="openCategoryModal(@item.CategoryId)"><i class="bi bi-pencil"></i></button>
                                <button class="btn btn-sm btn-outline-danger" onclick="deleteCategory(@item.CategoryId)"><i class="bi bi-trash"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="categoryModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog">
        <div class="modal-content bg-dark text-white border-secondary category-modal-custom">
            <div class="modal-header border-secondary">
                <h5 class="modal-title" id="modalTitle">Thông tin danh mục</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="categoryForm">
                    <input type="hidden" id="CategoryId" name="CategoryId" value="0" />

                    <div class="mb-3">
                        <label class="form-label text-secondary">Tên danh mục <span class="text-danger">*</span></label>
                        <input type="text" class="form-control bg-black text-white border-secondary" id="Name" name="Name" required placeholder="Nhập tên danh mục...">
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-secondary">Mô tả (Tùy chọn)</label>
                        <textarea class="form-control bg-black text-white border-secondary" id="Description" name="Description" rows="3" placeholder="Mô tả ngắn về danh mục này..."></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-secondary">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                <button type="button" class="btn btn-success" onclick="saveCategory()">Lưu danh mục</button>
            </div>
        </div>
    </div>
</div>
<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1055;">
    <div id="customToast" class="toast align-items-center text-white bg-dark border-0 border-start border-success border-4 shadow-lg" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body d-flex align-items-center">
                <i id="toastIcon" class="bi bi-check-circle-fill text-success fs-5 me-2"></i>
                <span id="toastMessage" class="fw-semibold" style="font-size: 0.95rem;">Thông báo</span>
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    </div>
</div>
<div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content bg-dark text-white border-secondary text-center p-3 shadow-lg">
            <div class="modal-body pb-1">
                <i class="bi bi-exclamation-triangle text-warning" style="font-size: 3.5rem;"></i>
                <h5 class="mt-3 fw-bold">Xóa danh mục?</h5>
                <p class="text-secondary small mt-2">
                    Bạn có chắc chắn muốn xóa danh mục này không? Hành động này không thể hoàn tác!
                </p>
                <input type="hidden" id="deleteCategoryId" value="0" />
            </div>
            <div class="d-flex justify-content-center gap-2 mb-2">
                <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">Thoát</button>
                <button type="button" class="btn btn-danger px-4" onclick="executeDeleteCategory()">Tiếp tục</button>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script src="~/js/admin-category.js"></script>
}