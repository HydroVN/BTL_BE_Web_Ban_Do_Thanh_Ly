@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>403 - Forbidden</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/access-denied.css" asp-append-version="true" />
</head>
<body class="denied-page">
    <div class="access-card shadow-lg">
        <div class="robot-container">
            <img src="~/images/accd/little-guy.gif" alt="Robot 403" class="robot-img">
        </div>

        <h1 class="display-5 fw-bold">Access Denied</h1>
        <p class="text-muted">Có vẻ như bạn không có đủ quyền hạn để truy cập vào trung tâm điều khiển Admin.</p>

        <div class="d-grid gap-2 d-md-flex justify-content-md-center mt-4">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg px-4">
                <i class="bi bi-arrow-left me-2"></i>Back to Home
            </a>

            <button class="btn btn-outline-secondary btn-lg px-4" id="btnSupport" data-bs-toggle="modal" data-bs-target="#contactSupportModal">
                Contact Support
            </button>
        </div>

        <div class="card-footer-info mt-5 pt-3 border-top border-secondary opacity-50">
            <div class="d-flex justify-content-between small">
                <span>ID: REF-8829-X</span>
                <span><i class="bi bi-dot text-danger"></i> Restricted Area</span>
            </div>
        </div>
    </div>

    <div class="modal fade" id="contactSupportModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content bg-black text-white border-secondary shadow-lg rounded-4 text-start">
                <div class="modal-header border-secondary border-bottom-0 pb-0 mt-2 px-4">
                    <h4 class="modal-title fw-bold" style="color: #f8fafc;">Contact Support</h4>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body pt-2 px-4 pb-4">
                    <p class="text-secondary mb-4">We're here to help! Reach out to us through any of the following channels:</p>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="card bg-black border-secondary h-100 contact-card-hover">
                                <div class="card-body d-flex flex-column p-4">
                                    <div class="d-flex align-items-start mb-3">
                                        <div class="contact-icon-box bg-primary bg-opacity-25 text-primary me-3">
                                            <i class="bi bi-envelope-fill fs-5"></i>
                                        </div>
                                        <div>
                                            <h6 class="fw-bold mb-1 text-white">Email Support</h6>
                                            <a href="https://mail.google.com/mail/?view=cm&fs=1&to=duyvan921@gmail.com" target="_blank" class="text-info text-decoration-none small fw-semibold">duyvan921@gmail.com</a>
                                        </div>
                                    </div>
                                    <p class="text-secondary small mb-4 flex-grow-1">Get a response within 24 hours.</p>
                                    <a href="https://mail.google.com/mail/?view=cm&fs=1&to=duyvan921@gmail.com" target="_blank" class="btn btn-outline-primary btn-sm w-100 fw-bold py-2">Send Email</a>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="card bg-black border-secondary h-100 contact-card-hover">
                                <div class="card-body d-flex flex-column p-4">
                                    <div class="d-flex align-items-start mb-3">
                                        <div class="contact-icon-box bg-success bg-opacity-25 text-success me-3">
                                            <i class="bi bi-telephone-fill fs-5"></i>
                                        </div>
                                        <div>
                                            <h6 class="fw-bold mb-1 text-white">Phone Support</h6>
                                            <a href="tel:+84123456789" class="text-success text-decoration-none small fw-semibold">+84 (0) 123 456 789</a>
                                        </div>
                                    </div>
                                    <p class="text-secondary small mb-4 flex-grow-1">Available Mon-Fri, 8am-6pm.</p>
                                    <a href="tel:+84123456789" class="btn btn-outline-success btn-sm w-100 fw-bold py-2">Call Now</a>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="card bg-black border-secondary h-100 contact-card-hover">
                                <div class="card-body d-flex flex-column p-4">
                                    <div class="d-flex align-items-start mb-3">
                                        <div class="contact-icon-box bg-info bg-opacity-25 text-info me-3">
                                            <i class="bi bi-facebook fs-5"></i>
                                        </div>
                                        <div>
                                            <h6 class="fw-bold mb-1 text-white">Facebook Support</h6>
                                            <span class="text-info small fw-semibold">Message Us</span>
                                        </div>
                                    </div>
                                    <p class="text-secondary small mb-4 flex-grow-1">Connect with us on Messenger for quick support.</p>

                                    <a href="https://www.facebook.com/van.hayasaka" target="_blank" class="btn btn-outline-info btn-sm w-100 fw-bold py-2">
                                        Open Facebook
                                    </a>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="card bg-black border-secondary h-100 contact-card-hover">
                                <div class="card-body d-flex flex-column p-4">
                                    <div class="d-flex align-items-start mb-3">
                                        <div class="contact-icon-box bg-danger bg-opacity-25 text-danger me-3">
                                            <i class="bi bi-geo-alt-fill fs-5"></i>
                                        </div>
                                        <div>
                                            <h6 class="fw-bold mb-1 text-white">Office Address</h6>
                                            <span class="text-danger small fw-semibold">1 Xốm, Phú Lâm, Hà Đông, Hà Nội 100000, Việt Nam</span>
                                        </div>
                                    </div>
                                    <p class="text-secondary small mb-4 flex-grow-1">Visit us during business hours.</p>
                                    <a href="https://maps.google.com/?q=Truong+Dai+Hoc+Dai+Nam,+Hanoi" target="_blank" class="btn btn-outline-danger btn-sm w-100 fw-bold py-2">Get Directions</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>