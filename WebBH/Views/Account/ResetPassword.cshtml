@model WebBH.Models.ResetPasswordVM
@{
    ViewData["Title"] = "Đặt Lại Mật Khẩu";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-body p-4 p-md-5">
                    <div class="text-center mb-4">
                        <i class="fas fa-key fa-3x text-success mb-3"></i>
                        <h3 class="fw-bold">Tạo Mật Khẩu Mới</h3>
                    </div>

                    @if (ViewBag.Error != null && Model?.Token == null)
                    {
                        <div class="alert alert-danger text-center">
                            <i class="fas fa-times-circle fs-4 mb-2"></i><br />
                            @ViewBag.Error
                        </div>
                        <div class="text-center mt-3">
                            <a asp-action="ForgotPassword" class="btn btn-outline-danger w-100">Gửi lại email yêu cầu</a>
                        </div>
                    }
                    else
                    {
                        @if (ViewBag.Error != null)
                        {
                            <div class="alert alert-danger">@ViewBag.Error</div>
                        }

                        <form asp-action="ResetPassword" method="post">
                            <input type="hidden" asp-for="Token" />

                            <div class="form-floating mb-3">
                                <input type="password" class="form-control" asp-for="NewPassword" placeholder="Mật khẩu mới (ít nhất 8 ký tự, 1 chữ hoa, 1 ký tự đặc biệt)" minlength="8">
                                <label asp-for="NewPassword">Mật khẩu mới</label>
                                <span asp-validation-for="NewPassword" class="text-danger small fw-bold mt-1 d-block"></span>
                            </div>

                            <div class="form-floating mb-4">
                                <input type="password" class="form-control" asp-for="ConfirmPassword" placeholder="Xác nhận mật khẩu" minlength="8">
                                <label asp-for="ConfirmPassword">Xác nhận mật khẩu mới</label>
                                <span asp-validation-for="ConfirmPassword" class="text-danger small fw-bold mt-1 d-block"></span>
                            </div>

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-success btn-lg fw-bold">Xác Nhận Đổi Mật Khẩu</button>
                            </div>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}